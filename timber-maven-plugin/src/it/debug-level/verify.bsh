String log = new String(java.nio.file.Files.readAllBytes(
    new java.io.File(basedir, "build.log").toPath()), "UTF-8");

// Debug mode enables all four isXEnabled checks: expected level = 3.
if (!log.contains("Output level: 3")) {
    throw new RuntimeException("Expected 'Output level: 3' — build log:\n" + log);
}
if (!log.contains("DETECTED timber.level=3")) {
    throw new RuntimeException("Expected 'DETECTED timber.level=3' — build log:\n" + log);
}

return true;
